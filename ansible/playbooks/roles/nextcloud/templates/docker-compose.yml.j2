services:
  db:
    image: postgres:16
    volumes:
      - nextcloud-postgres:/var/lib/postgresql/data
    environment:
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
    ports:
      - "5432:5432"
    networks:
      - nextcloud-network
    restart: unless-stopped

  nextcloud:
    image: nextcloud:29
    volumes:
      - nextcloud-data:/var/www/html
    environment:
      POSTGRES_HOST: db
      DB_PORT: 5432
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      NEXTCLOUD_ADMIN_USER: nextcloudadmin
      NEXTCLOUD_ADMIN_PASSWORD: adminpassword
      NEXTCLOUD_TRUSTED_DOMAINS: "{{ domain }} {{ host_ip }}"
    ports:
      - "80:80"
    networks:
      - nextcloud-network
    restart: unless-stopped
    depends_on:
      - db

volumes:
  nextcloud-data:
  nextcloud-postgres:


networks:
  nextcloud-network: